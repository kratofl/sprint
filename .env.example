# ── API Server ────────────────────────────────────────────────────────────────
PORT=8080
DATABASE_URL=postgres://sprint:changeme@localhost:5432/sprint?sslmode=disable
JWT_SECRET=changeme-use-a-long-random-string-in-production

# ── Web App ───────────────────────────────────────────────────────────────────
# URL the web app proxies /api/* requests to (default: http://localhost:8080)
API_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Postgres (docker-compose) ─────────────────────────────────────────────────
POSTGRES_DB=sprint
POSTGRES_USER=sprint
POSTGRES_PASSWORD=changeme
