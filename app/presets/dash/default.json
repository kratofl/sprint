{
  "id": "default",
  "name": "Default",
  "default": true,
  "gridCols": 20,
  "gridRows": 12,
  "idlePage": {
    "id": "idle-default",
    "name": "Idle",
    "widgets": [
      {"id": "idle-name", "type": "text", "col": 4, "row": 3, "colSpan": 12, "rowSpan": 3, "config": {"content": "Your Name"}},
      {"id": "idle-number", "type": "text", "col": 6, "row": 6, "colSpan": 8, "rowSpan": 2, "config": {"content": "#22"}}
    ]
  },
  "pages": [
    {
      "id": "main-default",
      "name": "Main",
      "widgets": [
        {"id": "header",     "type": "header",      "col":  0, "row":  0, "colSpan": 20, "rowSpan":  1},
        {"id": "rpm_bar",    "type": "rpm_bar",     "col":  0, "row":  1, "colSpan":  1, "rowSpan": 11},
        {"id": "gear_speed", "type": "gear_speed",  "col":  1, "row":  1, "colSpan":  7, "rowSpan":  5},
        {"id": "inputs",     "type": "input_trace", "col":  1, "row":  7, "colSpan":  7, "rowSpan":  3},
        {"id": "sectors",    "type": "sector",      "col":  1, "row": 10, "colSpan":  7, "rowSpan":  2},
        {"id": "lap_time",   "type": "lap_time",    "col":  9, "row":  1, "colSpan": 11, "rowSpan":  3},
        {"id": "delta",      "type": "delta",       "col":  9, "row":  5, "colSpan": 11, "rowSpan":  1},
        {"id": "fuel",       "type": "fuel",        "col":  9, "row":  6, "colSpan": 11, "rowSpan":  3},
        {"id": "tyre_temp",  "type": "tyre_temp",   "col":  9, "row":  9, "colSpan": 11, "rowSpan":  3}
      ]
    }
  ],
  "alerts": {
    "tcChange": true,
    "absChange": true,
    "engineMapChange": true
  }
}
